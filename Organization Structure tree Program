#include <iostream>
#include <vector>
#include <string>
using namespace std;

// Employee Node Structure
class Employee {
public:
    int empID;
    string name;
    string designation;
    vector<Employee*> subordinates;

    // Constructor
    Employee(int id, string empName, string role) {
        empID = id;
        name = empName;
        designation = role;
    }

    // Add Subordinate
    void addSubordinate(Employee* emp) {
        subordinates.push_back(emp);
    }
};

// Function to Display Organization Tree
void displayOrganization(Employee* root, int level = 0) {

    for(int i = 0; i < level; i++) {
        cout << "    ";
    }

    cout << "Employee ID : " << root->empID << endl;

    for(int i = 0; i < level; i++) {
        cout << "    ";
    }

    cout << "Employee Name : " << root->name << endl;

    for(int i = 0; i < level; i++) {
        cout << "    ";
    }

    cout << "Designation : " << root->designation << endl;

    for(int i = 0; i < level; i++) {
        cout << "    ";
    }

    cout << "----------------------------------" << endl;

    // Recursive Traversal
    for(Employee* emp : root->subordinates) {
        displayOrganization(emp, level + 1);
    }
}

// Function to Count Employees
int countEmployees(Employee* root) {

    int count = 1;

    for(Employee* emp : root->subordinates) {
        count += countEmployees(emp);
    }

    return count;
}

// Function to Search Employee
void searchEmployee(Employee* root, string searchName) {

    if(root->name == searchName) {
        cout << "\nEmployee Found\n";
        cout << "ID : " << root->empID << endl;
        cout << "Name : " << root->name << endl;
        cout << "Designation : " << root->designation << endl;
    }

    for(Employee* emp : root->subordinates) {
        searchEmployee(emp, searchName);
    }
}

